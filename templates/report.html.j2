// ── PR View ────────────────────────────────────────────────────────────────
function buildPRView(teamId, sprintId) {
  var wrap = document.getElementById('pr-table-wrap-' + teamId); if (!wrap) return;
  var sprintData = (teamStoryData[teamId]||{})[sprintId];
  var prByIndividual = sprintData ? (sprintData.prByIndividual||{}) : {};
  var teamAssignees = {};
  Object.keys(teamStoryData[teamId]||{}).forEach(function(sid){
    ((teamStoryData[teamId][sid]||{}).stories||[]).forEach(function(s){ if(s.assignedTo&&s.assignedTo!=='Unassigned') teamAssignees[s.assignedTo]=true; });
  });
  var hasTeamMap = Object.keys(teamAssignees).length > 0;
  var rows = Object.keys(prByIndividual)
    .filter(function(author){ if(!hasTeamMap) return true; var n=prByIndividual[author].assigned_to||''; return n!==''&&teamAssignees[n]===true; })
    .map(function(author){ return {author:author,data:prByIndividual[author]}; });
  rows.sort(function(a,b){ return b.data.prs_raised-a.data.prs_raised; });
  if (!rows.length) {
    wrap.innerHTML='<div class="pr-no-data">No PR data for this sprint.<br><small style="color:#aaa">PRs are tracked from GitHub links on ADO work items.</small></div>'; return;
  }
  var h='<table class="pr-table"><thead><tr>'
    +'<th>Individual (GitHub)</th><th style="text-align:right">PRs Raised</th>'
    +'<th style="text-align:right">Merged to Master</th><th style="text-align:right">Not Merged</th>'
    +'<th style="text-align:right">% Deployed</th>'
    +'<th style="text-align:right" title="AI Generated / AI Assisted / AI Powered">AI-Labeled PRs</th>'
    +'</tr></thead><tbody>';
  rows.forEach(function(r){
    var d=r.data, pct=d.pct_deployed;
    var pctClass=pct>=80?'pr-pct-green':(pct>=50?'pr-pct-amber':'pr-pct-red');
    var aiCount=d.ai_labeled||0, aiPrs=d.ai_labeled_prs||[];
    var aiCell=aiCount>0?'<button class="ai-count-btn" onclick=\'openAiPrModal('+JSON.stringify(r.author)+','+JSON.stringify(aiPrs)+')\'>&#129302; '+aiCount+'</button>':'<span style="color:#bbb">0</span>';
    h+='<tr><td>'+escHtml(r.author)+'</td><td class="num">'+d.prs_raised+'</td><td class="num">'+d.merged_to_master+'</td><td class="num">'+d.not_merged+'</td>'
      +'<td class="num '+pctClass+'">'+pct+'%</td><td class="num">'+aiCell+'</td></tr>';
  });
  wrap.innerHTML = h + '</tbody></table>';
}

// ── AI modal ───────────────────────────────────────────────────────────────
function openAiPrModal(author, prs) {
  var overlay=document.getElementById('ai-modal-overlay');
  var title=document.getElementById('ai-modal-title');
  var body=document.getElementById('ai-modal-body');
  title.textContent = '\u{1F916} AI-Labeled PRs — ' + author;
  if (!prs||!prs.length) {
    body.innerHTML='<p style="color:#888;padding:8px 0">No AI-labeled PRs found.</p>';
  } else {
    var rows=prs.map(function(p){
      var rc=escHtml(p.repo||'—'), prNum=p.number?'#'+p.number:'—';
      var lc=p.html_url?'<a class="ai-pr-link" href="'+escHtml(p.html_url)+'" target="_blank" rel="noopener">'+prNum+' &#8599;</a>':prNum;
      return '<tr><td>'+rc+'</td><td>'+lc+'</td></tr>';
    }).join('');
    body.innerHTML='<table class="ai-pr-table"><thead><tr><th>Repository</th><th>Pull Request</th></tr></thead><tbody>'+rows+'</tbody></table>';
  }
  overlay.classList.add('open');
}
function closeAiPrModal(){ document.getElementById('ai-modal-overlay').classList.remove('open'); }
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeAiPrModal(); });

