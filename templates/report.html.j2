// ── Team search & on-demand loading ─────────────────────────────────────────
var _allTeams = [];
var _loadedTeams = {};
var _focusedOption = -1;

fetch('/teams')
  .then(function(r){ return r.json(); })
  .then(function(teams){
    _allTeams = teams;
    if (teams.length > 0) _populateSearchDropdown('');
  });

function onTeamSearchFocus() {
  onTeamSearch(document.getElementById('team-search-input').value);
}

function onTeamSearch(q) {
  var dd = document.getElementById('team-search-dropdown');
  var filtered = q
    ? _allTeams.filter(function(t){ return t.name.toLowerCase().indexOf(q.toLowerCase()) !== -1; })
    : _allTeams;
  _populateSearchDropdown(q, filtered);
}

function _populateSearchDropdown(q, filtered) {
  if (!filtered) filtered = _allTeams;
  var dd = document.getElementById('team-search-dropdown');
  if (!filtered.length) { dd.style.display = 'none'; return; }
  dd.innerHTML = filtered.map(function(t){
    return '<div class="team-search-option" data-id="' + escHtml(t.id) + '" data-name="' + escHtml(t.name) +
           '" onmousedown="loadTeam(\'' + escHtml(t.id) + '\')">' + escHtml(t.name) + '</div>';
  }).join('');
  _focusedOption = -1;
  dd.style.display = 'block';
}

function onTeamSearchKey(e) {
  var dd = document.getElementById('team-search-dropdown');
  var opts = dd.querySelectorAll('.team-search-option');
  if (!opts.length) return;
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    _focusedOption = Math.min(_focusedOption + 1, opts.length - 1);
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    _focusedOption = Math.max(_focusedOption - 1, 0);
  } else if (e.key === 'Enter') {
    if (_focusedOption >= 0) {
      e.preventDefault();
      loadTeam(opts[_focusedOption].dataset.id);
    }
    return;
  } else if (e.key === 'Escape') {
    dd.style.display = 'none'; return;
  } else { return; }
  opts.forEach(function(o, i){ o.classList.toggle('focused', i === _focusedOption); });
  if (_focusedOption >= 0) opts[_focusedOption].scrollIntoView({block:'nearest'});
}

document.addEventListener('click', function(e){
  var bar = document.querySelector('.team-search-bar');
  if (bar && !bar.contains(e.target))
    document.getElementById('team-search-dropdown').style.display = 'none';
});

function loadTeam(teamId) {
  var team = _allTeams.find(function(t){ return t.id === teamId; });
  var teamName = team ? team.name : teamId;
  document.getElementById('team-search-input').value = teamName;
  document.getElementById('team-search-dropdown').style.display = 'none';

  if (_loadedTeams[teamId]) { switchTeam(teamId); return; }

  var loader = document.getElementById('team-loading');
  loader.style.display = 'inline';

  fetch('/team-panel/' + encodeURIComponent(teamId))
    .then(function(r){
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.text();
    })
    .then(function(html){
      loader.style.display = 'none';
      var container = document.querySelector('.container');
      container.insertAdjacentHTML('beforeend', html);
      _loadedTeams[teamId] = true;
      // Wire up assignee/tag dropdowns and draw charts for the newly added panel
      _initLoadedTeam(teamId);
      switchTeam(teamId);
    })
    .catch(function(err){
      loader.style.display = 'none';
      alert('Failed to load team data: ' + err.message);
    });
}

function _initLoadedTeam(teamId) {
  // Populate assignee filter
  var seenA = {};
  Object.keys(teamStoryData[teamId] || {}).forEach(function(sprintId){
    (teamStoryData[teamId][sprintId].stories || []).forEach(function(s){
      if (s.assignedTo) seenA[s.assignedTo] = true;
    });
  });
  var selA = document.getElementById('af-' + teamId);
  if (selA) Object.keys(seenA).sort().forEach(function(name){
    var opt = document.createElement('option');
    opt.value = name; opt.textContent = name;
    selA.appendChild(opt);
  });

  // Populate tag filter
  var seenT = {};
  Object.keys(teamStoryData[teamId] || {}).forEach(function(sprintId){
    (teamStoryData[teamId][sprintId].stories || []).forEach(function(s){
      (s.tags || []).forEach(function(tag){ if (tag) seenT[tag] = true; });
    });
  });
  var selT = document.getElementById('tag-select-' + teamId);
  if (selT) Object.keys(seenT).sort().forEach(function(tag){
    var opt = document.createElement('option');
    opt.value = tag; opt.textContent = tag;
    selT.appendChild(opt);
  });

  // Pre-select last sprint in PR view
  var prSel = document.getElementById('pr-sprint-sel-' + teamId);
  if (prSel && prSel.options.length) prSel.selectedIndex = prSel.options.length - 1;

  // Draw charts
  var d = chartData[teamId];
  if (d) {
    setTimeout(function(){
      drawBarChart('chart-' + teamId, d.labels, d.completed, d.total, false);
      drawVelocityChart('velocity-chart-' + teamId, d.labels, d.points_done, d.points_total);
    }, 50);
  }
}

// ── Live Refresh ────────────────────────────────────────────────────────────
var _refreshPollTimer = null;

function refreshDashboard() {
  var btn = document.getElementById('refresh-btn');
  btn.disabled = true;
  btn.textContent = 'Fetching...';

  fetch('/refresh', {method: 'POST'})
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.started || d.reason === 'already running') {
        _pollRefreshStatus();
      } else {
        btn.disabled = false;
        btn.textContent = 'Refresh Data';
      }
    })
    .catch(function() {
      btn.disabled = false;
      btn.textContent = 'Network error — try again';
    });
}

function _pollRefreshStatus() {
  var btn = document.getElementById('refresh-btn');
  var dots = 0;
  function tick() {
    dots = (dots % 3) + 1;
    btn.textContent = 'Fetching' + '.'.repeat(dots);
    fetch('/status')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) {
          btn.disabled = false;
          btn.textContent = 'Error — try again';
        } else if (!d.refreshing) {
          window.location.reload();
        } else {
          _refreshPollTimer = setTimeout(tick, 3000);
        }
      })
      .catch(function() {
        _refreshPollTimer = setTimeout(tick, 5000);
      });
  }
  tick();
}
{% endif %}
</script>

