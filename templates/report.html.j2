    var bugI='<svg width="12" height="12" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:3px"><circle cx="7" cy="7" r="7" fill="#cc3311"/><circle cx="7" cy="7" r="2.8" fill="none" stroke="#fff" stroke-width="1.4"/><line x1="7" y1="1.5" x2="7" y2="12.5" stroke="#fff" stroke-width="1.2"/><line x1="1.5" y1="7" x2="12.5" y2="7" stroke="#fff" stroke-width="1.2"/></svg>';
    var stI='<svg width="12" height="12" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:3px"><rect width="14" height="14" rx="2" fill="#773388"/><path d="M3 2h8v10L7 9.2 3 12z" fill="#fff" opacity=".9"/></svg>';
    var h='';
    (fe.stories||[]).forEach(function(s){
      var icon=s.witType==='Bug'?bugI:stI;
      var tc=s.adoUrl?'<a href="'+escHtml(s.adoUrl)+'" target="_blank" style="color:var(--text-link);text-decoration:none">'+icon+escHtml(s.title)+'</a>':icon+escHtml(s.title);
      h+='<tr><td style="white-space:nowrap;font-size:11px;color:#555">'+escHtml(s.sprintName||'')+'</td>'
        +'<td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+escHtml(s.title)+'">'+tc+'</td>'
        +'<td><span class="state-badge state-'+escHtml(s.state)+'">'+escHtml(s.state)+'</span></td>'
        +'<td style="white-space:nowrap">'+escHtml(s.assignedTo||'')+'</td>'
        +'<td class="num">'+(s.points||'—')+'</td></tr>';
    });
    tbody.innerHTML = h || '<tr><td colspan="5" style="text-align:center;color:#888;padding:12px">No items.</td></tr>';
  }
  document.getElementById('fdetail-' + teamId).classList.add('active');
}

function closeFeatureDetail(teamId) {
  var el = document.getElementById('fdetail-' + teamId); if(el) el.classList.remove('active');
