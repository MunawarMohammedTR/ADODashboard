<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>ADO Manager Dashboard — {{ project }}</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f0f2f5;color:#1a1a2e;font-size:14px}
.header{background:linear-gradient(135deg,#1a237e 0%,#0d47a1 100%);color:#fff;padding:18px 32px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 8px rgba(0,0,0,.25)}
.header h1{font-size:22px;font-weight:700;letter-spacing:.3px}
.header .meta{font-size:12px;opacity:.8;margin-top:4px}
.header .badge{background:rgba(255,255,255,.15);border-radius:20px;padding:4px 12px;font-size:12px}
.refresh-btn{background:rgba(255,255,255,.18);border:1.5px solid rgba(255,255,255,.5);color:#fff;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
.refresh-btn:hover:not(:disabled){background:rgba(255,255,255,.28)}
.refresh-btn:disabled{opacity:.55;cursor:not-allowed}
.container{max-width:1400px;margin:0 auto;padding:24px 32px}
/* Team search (serve mode) */
.team-search-bar{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.team-search-label{font-weight:600;font-size:13px;color:#1a237e;white-space:nowrap}
.team-search-wrap{position:relative}
.team-search-input{padding:8px 14px;border:2px solid #1a237e;border-radius:6px;font-size:13px;font-weight:600;color:#1a237e;background:#fff;min-width:260px;outline:none}
.team-search-input:focus{box-shadow:0 0 0 3px rgba(26,35,126,.2)}
.team-search-dropdown{position:absolute;top:calc(100% + 4px);left:0;min-width:260px;background:#fff;border:1.5px solid #1a237e;border-radius:6px;box-shadow:0 4px 16px rgba(0,0,0,.12);z-index:100;max-height:260px;overflow-y:auto;display:none}
.team-search-option{padding:10px 16px;cursor:pointer;font-size:13px;color:#1a237e}
.team-search-option:hover,.team-search-option.focused{background:#e8eaf6}
.team-loading{font-size:12px;color:#888;display:none}
/* Static dropdown (batch mode) */
.team-select-bar{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.team-select-label{font-weight:600;font-size:13px;color:#1a237e}
.team-select{padding:8px 14px;border:2px solid #1a237e;border-radius:6px;font-size:13px;font-weight:600;color:#1a237e;background:#fff;cursor:pointer;min-width:220px;outline:none}
.team-select:focus{box-shadow:0 0 0 3px rgba(26,35,126,.2)}
.team-panel{display:none}
.team-panel.active{display:block}

/* Assignee filter */
.af-bar{background:#fff;border-radius:10px;padding:10px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08);margin-bottom:16px;display:flex;align-items:center;gap:12px}
.af-label{font-weight:700;color:#1a237e;font-size:13px;white-space:nowrap}
.assignee-select{padding:5px 12px;border:1.5px solid #c5cae9;border-radius:6px;font-size:13px;background:#fff;cursor:pointer;min-width:200px;color:#1a237e}
.assignee-select:focus{outline:none;border-color:#1a237e}

/* Tag filter */
.tag-bar{background:#fff;border-radius:10px;padding:10px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08);margin-bottom:16px;display:flex;align-items:center;gap:12px}
.tag-label{font-weight:700;color:#1a237e;font-size:13px;white-space:nowrap}
.tag-select{padding:5px 12px;border:1.5px solid #c5cae9;border-radius:6px;font-size:13px;background:#fff;cursor:pointer;min-width:200px;color:#1a237e}
.tag-select:focus{outline:none;border-color:#1a237e}

/* Sprint bar */
.sprint-bar{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.sprint-bar label{font-weight:600;color:#1a237e}
.sprint-select{padding:7px 12px;border:1px solid #c5cae9;border-radius:6px;font-size:13px;background:#fff;cursor:pointer;min-width:220px}

/* Summary cards */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:24px}
.card{background:#fff;border-radius:10px;padding:18px;box-shadow:0 1px 4px rgba(0,0,0,.08);text-align:center}
.card .value{font-size:32px;font-weight:700;color:#1a237e}
.card .label{font-size:12px;color:#666;margin-top:4px;font-weight:500}
.card.warn .value{color:#e65100}

/* Person summary panel */
.person-summary{background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);margin-bottom:24px;overflow:hidden}
.person-summary-header{background:#283593;color:#fff;padding:13px 20px;display:flex;align-items:center;justify-content:space-between}
.person-summary-header h3{font-size:14px;font-weight:700}
.person-summary-header .close-btn{cursor:pointer;font-size:18px;opacity:.7;line-height:1}
.person-summary-header .close-btn:hover{opacity:1}
.person-summary-body{padding:20px;display:flex;gap:24px;flex-wrap:wrap}
.person-sprint-table-wrap{flex:1;min-width:300px;overflow:auto}
.person-sprint-table{width:100%;border-collapse:collapse;font-size:13px}
.person-sprint-table th{background:#e8eaf6;color:#1a237e;padding:8px 12px;text-align:left;font-weight:700;white-space:nowrap}
.person-sprint-table td{padding:8px 12px;border-bottom:1px solid #e8eaf6}
.person-sprint-table tr:last-child td{border-bottom:none}
.person-sprint-table .num{text-align:right}
.person-sprint-table .pct-cell{text-align:right}
.pct-bar-wrap{display:flex;align-items:center;gap:8px;justify-content:flex-end}
.pct-bar-bg{height:8px;width:80px;background:#e8eaf6;border-radius:4px;overflow:hidden}
.pct-bar-fill{height:8px;border-radius:4px;background:#1a237e;transition:width .3s}
.person-chart-wrap{flex:1;min-width:260px}
canvas.person-canvas{max-height:200px}

/* Chart wrapper */
.chart-wrapper{background:#fff;border-radius:10px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.08);margin-bottom:24px}
.chart-wrapper h3{font-size:14px;font-weight:600;color:#1a237e;margin-bottom:12px}
canvas{max-height:400px}
.chart-wrapper canvas{max-height:400px;width:100%}

/* Story table */
.table-wrapper{background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);overflow:auto;margin-bottom:32px}
.table-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px 0}
.table-header .filter-note{font-size:12px;color:#555;font-style:italic}
table{width:100%;border-collapse:collapse;font-size:13px}
thead th{background:#1a237e;color:#fff;padding:10px 12px;text-align:left;position:sticky;top:0;white-space:nowrap;font-weight:600}
tbody tr:nth-child(even){background:#f5f7ff}
tbody tr:hover{background:#e8eaf6}
tbody tr.hidden-row{display:none}
td{padding:9px 12px;vertical-align:middle;border-bottom:1px solid #e8eaf6}
td.id-col{font-weight:700;color:#0d47a1;white-space:nowrap}
td.id-col a{color:#0d47a1;text-decoration:none}
td.id-col a:hover{text-decoration:underline}
td.title-col{max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.state-badge{display:inline-block;padding:2px 9px;border-radius:12px;font-size:11px;font-weight:700}
.state-Active,.state-In\ Progress{background:#e3f2fd;color:#0277bd}
.state-Resolved,.state-Done,.state-Closed{background:#e8f5e9;color:#2e7d32}
.state-New,.state-To\ Do{background:#fff8e1;color:#f57f17}
.state-Removed{background:#fce4ec;color:#c62828}
.audit{text-align:center;font-size:16px}
.pass{color:#2e7d32}
.fail{color:#c62828}
.points-col{text-align:right;font-weight:600}
.assigned-col{white-space:nowrap;overflow:hidden;max-width:140px;text-overflow:ellipsis}
.sprint-summary-panel{display:none}
.sprint-summary-panel.active{display:block}
.no-data{text-align:center;padding:40px;color:#888;font-size:15px}
.no-visible-rows{display:none;text-align:center;padding:20px;color:#888;font-size:13px}
.effort-col{text-align:right;font-weight:600;white-space:nowrap}
.wip-star{color:#e65100;font-size:10px;vertical-align:super;font-weight:700}
.state-In\ Development{background:#e3f2fd;color:#0277bd}
.state-QA{background:#f3e5f5;color:#6a1b9a}
/* Health score */
.health-badge{display:inline-flex;align-items:center;gap:6px;padding:3px 11px;border-radius:14px;font-size:12px;font-weight:700;letter-spacing:.2px}
.health-green{background:#e8f5e9;color:#2e7d32;border:1.5px solid #a5d6a7}
.health-amber{background:#fff8e1;color:#f57f17;border:1.5px solid #ffe082}
.health-red{background:#fce4ec;color:#c62828;border:1.5px solid #ef9a9a}
.health-dot{width:9px;height:9px;border-radius:50%;display:inline-block;flex-shrink:0}
.health-dot-green{background:#43a047}
.health-dot-amber{background:#ffa000}
.health-dot-red{background:#e53935}
.card.health-green .value{color:#2e7d32}
.card.health-amber .value{color:#f57f17}
.card.health-red .value{color:#c62828}
.sprint-health-bar{display:flex;align-items:center;gap:10px;margin-bottom:18px;padding:10px 16px;border-radius:8px;font-size:13px;font-weight:600}
.sprint-health-bar.green{background:#e8f5e9;border:1.5px solid #a5d6a7;color:#2e7d32}
.sprint-health-bar.amber{background:#fff8e1;border:1.5px solid #ffe082;color:#b45309}
.sprint-health-bar.red{background:#fce4ec;border:1.5px solid #ef9a9a;color:#c62828}
/* Completed-items panel inside person summary */
.ps-completed-section{border-top:1px solid #e8eaf6;padding:16px 20px 20px}
.ps-completed-section h4{font-size:13px;font-weight:700;color:#1a237e;margin-bottom:10px}
.ps-completed-table{width:100%;border-collapse:collapse;font-size:12px}
.ps-completed-table th{background:#e8eaf6;color:#1a237e;padding:7px 10px;text-align:left;font-weight:700;white-space:nowrap;position:sticky;top:0}
.ps-completed-table td{padding:7px 10px;border-bottom:1px solid #f0f2f5;vertical-align:middle}
.ps-completed-table tr:last-child td{border-bottom:none}
.ps-completed-table .num{text-align:right;font-weight:600}
.ps-completed-wrap{max-height:320px;overflow-y:auto;border:1px solid #e8eaf6;border-radius:6px}

/* View toggle */
.view-toggle{display:flex;gap:0;margin-bottom:20px;border:2px solid #1a237e;border-radius:8px;overflow:hidden;width:fit-content}
.view-btn{padding:8px 22px;font-size:13px;font-weight:700;cursor:pointer;background:#fff;color:#1a237e;border:none;transition:all .15s}
.view-btn.active{background:#1a237e;color:#fff}
.view-panel{display:none}
.view-panel.active{display:block}

/* PR View */
.pr-sprint-bar{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.pr-sprint-bar label{font-weight:600;color:#1a237e}
.pr-sprint-sel{padding:7px 12px;border:1px solid #c5cae9;border-radius:6px;font-size:13px;background:#fff;cursor:pointer;min-width:220px}
.pr-table-wrap{background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);overflow:auto;margin-bottom:32px}
.pr-table{width:100%;border-collapse:collapse;font-size:13px}
.pr-table thead th{background:#1a237e;color:#fff;padding:10px 14px;text-align:left;position:sticky;top:0;white-space:nowrap;font-weight:600}
.pr-table tbody tr:nth-child(even){background:#f5f7ff}
.pr-table tbody tr:hover{background:#e8eaf6}
.pr-table td{padding:10px 14px;border-bottom:1px solid #e8eaf6;vertical-align:middle}
.pr-table td.num{text-align:right;font-weight:600}
.pr-pct-green{color:#2e7d32;font-weight:700}
.pr-pct-amber{color:#b45309;font-weight:700}
.pr-pct-red{color:#c62828;font-weight:700}
.pr-no-data{text-align:center;padding:40px;color:#888;font-size:15px}
.ai-count-btn{background:#e8f5e9;color:#2e7d32;font-weight:700;padding:2px 8px;border-radius:10px;font-size:12px;cursor:pointer;border:none;font-family:inherit}
.ai-count-btn:hover{background:#c8e6c9}
/* AI PR list modal */
.ai-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9000;align-items:center;justify-content:center}
.ai-modal-overlay.open{display:flex}
.ai-modal{background:#fff;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.22);width:600px;max-width:92vw;max-height:80vh;display:flex;flex-direction:column}
.ai-modal-header{background:#1a237e;color:#fff;padding:14px 20px;border-radius:12px 12px 0 0;display:flex;align-items:center;justify-content:space-between}
.ai-modal-header h3{font-size:14px;font-weight:700;margin:0}
.ai-modal-close{background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1;opacity:.8}
.ai-modal-close:hover{opacity:1}
.ai-modal-body{overflow-y:auto;padding:16px 20px}
.ai-pr-table{width:100%;border-collapse:collapse;font-size:13px}
.ai-pr-table th{background:#e8eaf6;color:#1a237e;padding:8px 12px;text-align:left;font-weight:600;white-space:nowrap}
.ai-pr-table td{padding:8px 12px;border-bottom:1px solid #e8eaf6;vertical-align:middle}
.ai-pr-table tr:hover td{background:#f5f7ff}
.ai-pr-link{color:#0d47a1;text-decoration:none;font-weight:600}
.ai-pr-link:hover{text-decoration:underline}

/* Feature cards */
.feature-cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;margin-bottom:24px}
.feature-card{background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.09);padding:16px 18px;cursor:pointer;border:2px solid transparent;transition:border-color .15s}
.feature-card:hover{border-color:#7986cb}
.feature-card.active{border-color:#1a237e;box-shadow:0 2px 8px rgba(26,35,126,.18)}
.fc-name{font-size:13px;font-weight:700;color:#1a237e;margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fc-counts{font-size:12px;color:#555;margin-bottom:6px}
.fc-bar-bg{height:7px;background:#e8eaf6;border-radius:4px;overflow:hidden;margin-bottom:4px}
.fc-bar-fill{height:7px;border-radius:4px;background:#1a237e;transition:width .3s}
.fc-pct{font-size:11px;font-weight:700;color:#1a237e}
.fc-roadblock-badge{display:inline-block;margin-top:6px;padding:2px 9px;border-radius:12px;font-size:11px;font-weight:700;background:#fff3e0;color:#e65100;border:1px solid #ffcc80}

/* Feature detail panel */
.feature-detail{background:#fff;border-radius:10px;box-shadow:0 1px 6px rgba(0,0,0,.1);margin-bottom:24px;overflow:hidden;display:none}
.feature-detail.active{display:block}
.fd-header{background:#283593;color:#fff;padding:13px 20px;display:flex;align-items:center;justify-content:space-between}
.fd-header h3{font-size:14px;font-weight:700}
.fd-close{cursor:pointer;font-size:18px;opacity:.7;line-height:1}
.fd-close:hover{opacity:1}
.fd-body{padding:20px;display:flex;gap:24px;flex-wrap:wrap}
.fd-chart-wrap{flex:1;min-width:260px}
.fd-roadblocks{flex:1;min-width:220px;background:#fff8f0;border:1px solid #ffcc80;border-radius:8px;padding:14px}
.fd-roadblocks h4{font-size:12px;font-weight:700;color:#e65100;margin-bottom:8px}
.fd-roadblocks ul{margin:0;padding-left:16px;font-size:12px;color:#555;line-height:1.7}
.fd-table-wrap{width:100%;overflow:auto}
.fd-table{width:100%;border-collapse:collapse;font-size:12px}
.fd-table th{background:#e8eaf6;color:#1a237e;padding:7px 10px;text-align:left;font-weight:700;white-space:nowrap;position:sticky;top:0}
.fd-table td{padding:7px 10px;border-bottom:1px solid #f0f2f5;vertical-align:middle}
.fd-table tr:last-child td{border-bottom:none}
.fd-table .num{text-align:right;font-weight:600}
.fd-section-header{padding:0 20px 6px;font-size:13px;font-weight:700;color:#1a237e;border-top:1px solid #e8eaf6;padding-top:14px}


</style>
</head>
<body>
<div class="header">
  <div>
    <div class="h1-row" style="display:flex;align-items:center;gap:12px">
      <h1>ADO Manager Dashboard</h1>
      <span class="badge">{{ project }}</span>
    </div>
    <div class="meta">Generated {{ generated_at }}</div>
  </div>
  <div style="display:flex;align-items:center;gap:16px">
    <div style="text-align:right;font-size:12px;opacity:.8">
      {{ teams | length }} team(s) &nbsp;|&nbsp; {{ sprint_count }} sprint(s) per team
    </div>
    {% if serve_mode %}
    <button class="refresh-btn" id="refresh-btn" onclick="refreshDashboard()">&#8635; Refresh Data</button>
    {% endif %}
  </div>
</div>

<div class="container">

  {% if serve_mode %}
  <!-- Live team search (serve mode) -->
  <div class="team-search-bar">
    <label class="team-search-label">Team:</label>
    <div class="team-search-wrap">
      <input id="team-search-input" class="team-search-input" type="text"
             placeholder="Search teams..." autocomplete="off"
             oninput="onTeamSearch(this.value)" onfocus="onTeamSearchFocus()"
             onkeydown="onTeamSearchKey(event)">
      <div id="team-search-dropdown" class="team-search-dropdown"></div>
    </div>
    <span id="team-loading" class="team-loading">Loading...</span>
  </div>
  {% else %}
  <!-- Static team dropdown (batch mode) -->
  <div class="team-select-bar">
    <label class="team-select-label" for="team-select">Team:</label>
    <select id="team-select" class="team-select" onchange="switchTeam(this.value)">
      {% for team in teams %}
      <option value="{{ team.id }}">{{ team.name }}</option>
      {% endfor %}
    </select>
  </div>
  {% endif %}

  {% for team in teams %}
  <div class="team-panel{% if loop.first %} active{% endif %}" id="team-{{ team.id }}">

    <!-- View toggle: Sprint / Feature / PR -->
    <div class="view-toggle">
      <div class="view-btn active" id="vbtn-sprint-{{ team.id }}" onclick="toggleView('{{ team.id }}','sprint')">Sprint View</div>
      <div class="view-btn" id="vbtn-feature-{{ team.id }}" onclick="toggleView('{{ team.id }}','feature')">Feature View</div>
      <div class="view-btn" id="vbtn-pr-{{ team.id }}" onclick="toggleView('{{ team.id }}','pr')">PR View</div>
    </div>

    <!-- ══════════ SPRINT VIEW ══════════ -->
    <div class="view-panel active" id="sprint-view-{{ team.id }}">

    <!-- Assigned To filter -->
    <div class="af-bar">
      <span class="af-label">Assigned To:</span>
      <select class="assignee-select" id="af-{{ team.id }}" onchange="onAssigneeChange('{{ team.id }}', this.value)">
        <option value="">All</option>
      </select>
    </div>

    <!-- Tag filter -->
    <div class="tag-bar">
      <span class="tag-label">Tags:</span>
      <select class="tag-select" id="tag-select-{{ team.id }}" onchange="applyTagFilter('{{ team.id }}', this.value)">
        <option value="">All Tags</option>
      </select>
    </div>

    <!-- Person cross-sprint summary (shown when a person pill is active) -->
    <div class="person-summary" id="ps-{{ team.id }}" style="display:none">
      <div class="person-summary-header">
        <h3 id="ps-title-{{ team.id }}"></h3>
        <span class="close-btn" onclick="clearAssigneeFilter('{{ team.id }}')">&#10005;</span>
      </div>
      <div class="person-summary-body">
        <div class="person-sprint-table-wrap">
          <table class="person-sprint-table">
            <thead>
              <tr>
                <th>Sprint</th>
                <th class="num">Assigned</th>
                <th class="num">Completed</th>
                <th class="num">Points Done</th>
                <th class="pct-cell">Completion</th>
              </tr>
            </thead>
            <tbody id="ps-tbody-{{ team.id }}"></tbody>
          </table>
        </div>
        <div class="person-chart-wrap">
          <canvas class="person-canvas" id="ps-chart-{{ team.id }}"></canvas>
        </div>
      </div>
      <!-- All completed items for this person across all sprints -->
      <div class="ps-completed-section">
        <h4 id="ps-completed-title-{{ team.id }}">All Completed Items</h4>
        <div class="ps-completed-wrap" id="ps-completed-{{ team.id }}"></div>
      </div>
    </div>

    <!-- Sprint selector -->
    <div class="sprint-bar">
      <label>Sprint:</label>
      <select class="sprint-select" onchange="switchSprint('{{ team.id }}', this.value)">
        {% for sprint in team.sprints %}
        {% set hl = sprint.data.health_label %}
        <option value="{{ sprint.id }}">{{ sprint.name }} {% if hl == 'green' %}✔{% elif hl == 'amber' %}⚠{% else %}✘{% endif %} {{ sprint.data.health_score }}</option>
        {% endfor %}
      </select>
    </div>

    {% for sprint in team.sprints %}
    {% set sdata = sprint.data %}
    <div class="sprint-summary-panel{% if loop.first %} active{% endif %}" id="sprint-{{ team.id }}-{{ sprint.id }}">

      <!-- Sprint health banner -->
      {% set hl = sdata.health_label %}
      <div class="sprint-health-bar {{ hl }}">
        <span class="health-dot health-dot-{{ hl }}"></span>
        Sprint Health Score: <strong>{{ sdata.health_score }} / 100</strong>
        &nbsp;—&nbsp;
        {% if hl == 'green' %}Healthy sprint
        {% elif hl == 'amber' %}Needs attention
        {% else %}At risk
        {% endif %}
        <span style="margin-left:auto;font-size:11px;font-weight:400;opacity:.8">
          Completion {{ sdata.completed }}/{{ sdata.total }} &nbsp;|&nbsp; Audit {{ sdata.audit_pass_rate }}%
        </span>
      </div>

      <!-- Summary cards (static; updated by JS when filtered) -->
      <div class="cards" id="cards-{{ team.id }}-{{ sprint.id }}">
        <div class="card">
          <div class="value" id="c-total-{{ team.id }}-{{ sprint.id }}">{{ sdata.total }}</div>
          <div class="label">Work Items</div>
        </div>
        <div class="card">
          <div class="value" id="c-done-{{ team.id }}-{{ sprint.id }}">{{ sdata.completed }}</div>
          <div class="label">Completed</div>
        </div>
        <div class="card">
          <div class="value" id="c-pts-{{ team.id }}-{{ sprint.id }}">{{ sdata.total_points }}</div>
          <div class="label">Story Points</div>
        </div>
        <div class="card">
          <div class="value" id="c-donepts-{{ team.id }}-{{ sprint.id }}">{{ sdata.completed_points }}</div>
          <div class="label">Points Done</div>
        </div>
        <div class="card">
          <div class="value" id="c-rate-{{ team.id }}-{{ sprint.id }}">{{ sdata.audit_pass_rate }}%</div>
          <div class="label">Audit Pass Rate</div>
        </div>
        <div class="card health-{{ sdata.health_label }}">
          <div class="value">{{ sdata.health_score }}</div>
          <div class="label">Health Score</div>
        </div>
        <div class="card">
          <div class="value" id="c-devdays-{{ team.id }}-{{ sprint.id }}">{{ sdata.avg_dev_days if sdata.avg_dev_days is not none else '—' }}</div>
          <div class="label">Avg Dev Days</div>
        </div>
        <div class="card">
          <div class="value" id="c-qadays-{{ team.id }}-{{ sprint.id }}">{{ sdata.avg_qa_days if sdata.avg_qa_days is not none else '—' }}</div>
          <div class="label">Avg QA Days</div>
        </div>
      </div>

      <!-- Filter note -->
      <div class="filter-note" id="fn-{{ team.id }}-{{ sprint.id }}" style="display:none;margin-bottom:12px;padding:6px 14px;background:#e8eaf6;border-radius:6px;font-size:12px;color:#1a237e"></div>

      <!-- Audit table -->
      {% if sdata.stories %}
      <div class="table-wrapper">
        <table id="tbl-{{ team.id }}-{{ sprint.id }}">
          <thead>
            <tr>
              <th>ID</th>
              <th>Title</th>
              <th>State</th>
              <th>Assigned To</th>
              <th style="text-align:right">Points</th>
              <th title="Acceptance Criteria filled">AC</th>
              <th title="At least one GitHub PR linked">PR</th>
              <th title="At least one commit linked">Commits</th>
              <th title="GitHub PR has an approved review">Reviewed</th>
              <th title="Calendar days in 'In Development' state" style="text-align:right">Dev Days</th>
              <th title="Calendar days in 'QA' state" style="text-align:right">QA Days</th>
            </tr>
          </thead>
          <tbody>
            {% for s in sdata.stories %}
            <tr data-assignee="{{ s.assigned_to | e }}" data-tags="{{ s.tags | join(';') }}">
              <td class="id-col"><a href="{{ s.ado_url }}" target="_blank">#{{ s.id }}</a></td>
              <td class="title-col" title="{{ s.title }}">
                {% if s.work_item_type == 'Bug' %}
                <svg width="14" height="14" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:4px;flex-shrink:0" title="Bug"><circle cx="7" cy="7" r="7" fill="#cc3311"/><circle cx="7" cy="7" r="2.8" fill="none" stroke="#fff" stroke-width="1.4"/><line x1="7" y1="1.5" x2="7" y2="12.5" stroke="#fff" stroke-width="1.2"/><line x1="1.5" y1="7" x2="12.5" y2="7" stroke="#fff" stroke-width="1.2"/></svg>
                {% else %}
                <svg width="14" height="14" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:4px;flex-shrink:0" title="User Story"><rect width="14" height="14" rx="2" fill="#773388"/><path d="M3 2h8v10L7 9.2 3 12z" fill="#fff" opacity=".9"/></svg>
                {% endif %}{{ s.title }}</td>
              <td><span class="state-badge state-{{ s.state | replace(' ', '\\ ') }}">{{ s.state }}</span></td>
              <td class="assigned-col" title="{{ s.assigned_to }}">{{ s.assigned_to }}</td>
              <td class="points-col">{{ s.story_points if s.story_points else '—' }}</td>
              <td class="audit">{% if s.has_ac %}<span class="pass" title="AC present">✔</span>{% else %}<span class="fail" title="Missing AC">✘</span>{% endif %}</td>
              <td class="audit">{% if s.has_pr %}<span class="pass" title="PR linked">✔</span>{% else %}<span class="fail" title="No PR linked">✘</span>{% endif %}</td>
              <td class="audit">{% if s.has_commit %}<span class="pass" title="Commit linked">✔</span>{% else %}<span class="fail" title="No commit">✘</span>{% endif %}</td>
              <td class="audit">{% if s.pr_reviewed %}<span class="pass" title="Approved review">✔</span>{% elif not s.has_pr %}<span style="color:#bbb" title="No PR">—</span>{% else %}<span class="fail" title="No approved review">✘</span>{% endif %}</td>
              <td class="effort-col">{% if s.dev_days is not none %}{{ s.dev_days }}{% if s.dev_wip %}<span class="wip-star" title="Still in development">*</span>{% endif %}{% else %}—{% endif %}</td>
              <td class="effort-col">{% if s.qa_days is not none %}{{ s.qa_days }}{% if s.qa_wip %}<span class="wip-star" title="Still in QA">*</span>{% endif %}{% else %}—{% endif %}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        <div class="no-visible-rows" id="nvr-{{ team.id }}-{{ sprint.id }}">No stories assigned to this person in this sprint.</div>
      </div>
      {% else %}
      <div class="no-data">No work items found in this sprint.</div>
      {% endif %}

    </div>
    {% endfor %}

    <!-- Sprint-over-sprint bar chart -->
    <div class="chart-wrapper">
      <h3>Sprint Progress — {{ team.name }}</h3>
      <canvas id="chart-{{ team.id }}"></canvas>
    </div>

    <!-- Velocity trend line chart -->
    <div class="chart-wrapper">
      <h3>Velocity Trend (Story Points) — {{ team.name }}</h3>
      <canvas id="velocity-chart-{{ team.id }}"></canvas>
    </div>

    </div>{# end sprint-view #}

    <!-- ══════════ FEATURE VIEW ══════════ -->
    <div class="view-panel" id="feature-view-{{ team.id }}">

      <!-- Feature cards -->
      <div class="feature-cards-grid" id="fcards-{{ team.id }}">
        <!-- populated by JS -->
      </div>

      <!-- Feature detail panel (shown on card click) -->
      <div class="feature-detail" id="fdetail-{{ team.id }}">
        <div class="fd-header">
          <h3 id="fd-title-{{ team.id }}"></h3>
          <span class="fd-close" onclick="closeFeatureDetail('{{ team.id }}')">&#10005;</span>
        </div>
        <div class="fd-body">
          <div class="fd-chart-wrap">
            <canvas id="fd-chart-{{ team.id }}" style="max-height:180px"></canvas>
          </div>
          <div class="fd-roadblocks" id="fd-roadblocks-{{ team.id }}"></div>
        </div>
        <div class="fd-section-header">Work Items</div>
        <div class="fd-table-wrap" style="padding:0 20px 20px">
          <table class="fd-table">
            <thead>
              <tr>
                <th>Sprint</th><th>Title</th><th>State</th>
                <th>Assigned To</th><th class="num">Points</th>
              </tr>
            </thead>
            <tbody id="fd-tbody-{{ team.id }}"></tbody>
          </table>
        </div>
      </div>

    </div>{# end feature-view #}

    <!-- ══════════ PR VIEW ══════════ -->
    <div class="view-panel" id="pr-view-{{ team.id }}">

      <!-- Sprint selector for PR view -->
      <div class="pr-sprint-bar">
        <label>Sprint:</label>
        <select class="pr-sprint-sel" id="pr-sprint-sel-{{ team.id }}" onchange="buildPRView('{{ team.id }}', this.value)">
          {% for sprint in team.sprints %}
          {% if not sprint.is_backlog %}
          <option value="{{ sprint.id }}">{{ sprint.name }}</option>
          {% endif %}
          {% endfor %}
        </select>
      </div>

      <!-- PR table populated by JS -->
      <div class="pr-table-wrap" id="pr-table-wrap-{{ team.id }}">
        <div class="pr-no-data">Select a sprint to view PR statistics.</div>
      </div>

    </div>{# end pr-view #}

  </div>
  {% endfor %}

</div>

<script>
// ── Story data for all teams/sprints (used by assignee filter JS) ──────────
var teamStoryData = {{ story_data | tojson }};
// Structure: { teamId: { sprintId: { name, stories: [{assignedTo, state, points, completedPoints}] } } }

var DONE_STATES = {'Resolved':1,'Done':1,'Closed':1};

// ── Filter state ──────────────────────────────────────────────────────────
var activeAssignee = {};  // teamId → assignee name or ""
var activeTag      = {};  // teamId → tag string or ""

function buildAssigneeFilters() {
  Object.keys(teamStoryData).forEach(function(teamId) {
    var seen = {};
    Object.keys(teamStoryData[teamId]).forEach(function(sprintId) {
      (teamStoryData[teamId][sprintId].stories || []).forEach(function(s) {
        if (s.assignedTo) seen[s.assignedTo] = true;
      });
    });
    var names = Object.keys(seen).sort();
    var sel = document.getElementById('af-' + teamId);
    if (!sel) return;
    names.forEach(function(name) {
      var opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      sel.appendChild(opt);
    });
  });
}

function onAssigneeChange(teamId, assignee) {
  if (!assignee) {
    clearAssigneeFilter(teamId);
  } else {
    applyAssigneeFilter(teamId, assignee);
  }
}

function applyAssigneeFilter(teamId, assignee) {
  activeAssignee[teamId] = assignee;

  // Filter rows in every sprint table for this team
  var teamData = teamStoryData[teamId] || {};
  Object.keys(teamData).forEach(function(sprintId) {
    filterSprintTable(teamId, sprintId);
  });

  // Auto-switch to most recent non-backlog sprint
  var nonBacklog = Object.keys(teamData).filter(function(id) {
    return teamData[id].isCurrent;
  });
  if (nonBacklog.length > 0) {
    nonBacklog.sort(function(a, b) {
      var na = teamData[a].name || ''; var nb = teamData[b].name || '';
      return na < nb ? -1 : na > nb ? 1 : 0;
    });
    var latestId = nonBacklog[nonBacklog.length - 1];
    var sel = document.querySelector('#team-' + teamId + ' .sprint-select');
    if (sel) sel.value = latestId;
    switchSprint(teamId, latestId);
  }

  // Show person summary panel
  showPersonSummary(teamId, assignee);
}

function clearAssigneeFilter(teamId) {
  activeAssignee[teamId] = '';

  // Show all rows in all sprint tables
  var teamData = teamStoryData[teamId] || {};
  Object.keys(teamData).forEach(function(sprintId) {
    filterSprintTable(teamId, sprintId);
  });

  // Hide person summary
  var ps = document.getElementById('ps-' + teamId);
  if (ps) ps.style.display = 'none';
}

function filterSprintTable(teamId, sprintId) {
  var assignee = activeAssignee[teamId] || '';
  var tag      = activeTag[teamId]      || '';
  var tbl = document.getElementById('tbl-' + teamId + '-' + sprintId);
  if (!tbl) return;

  var rows = tbl.querySelectorAll('tbody tr');
  var visible = 0;
  rows.forEach(function(row) {
    var ra = row.getAttribute('data-assignee') || '';
    var rt = row.getAttribute('data-tags') || '';
    var tagArr = rt ? rt.split(';').map(function(t){ return t.trim(); }) : [];
    var show = (!assignee || ra === assignee) && (!tag || tagArr.indexOf(tag) !== -1);
    row.classList.toggle('hidden-row', !show);
    if (show) visible++;
  });

  updateCardsForFilter(teamId, sprintId);

  var nvr = document.getElementById('nvr-' + teamId + '-' + sprintId);
  if (nvr) nvr.style.display = (visible === 0 && (assignee || tag)) ? 'block' : 'none';

  var fn = document.getElementById('fn-' + teamId + '-' + sprintId);
  if (fn) {
    var parts = [];
    if (assignee) parts.push('assigned to ' + assignee);
    if (tag) parts.push('tag: ' + tag);
    if (parts.length) {
      fn.style.display = 'block';
      fn.textContent = 'Filtered: showing ' + visible + ' item' + (visible===1?'':'s') + ' — ' + parts.join(', ');
    } else {
      fn.style.display = 'none';
    }
  }
}

function updateCardsForFilter(teamId, sprintId) {
  var assignee = activeAssignee[teamId] || '';
  var tag      = activeTag[teamId]      || '';
  var data = (teamStoryData[teamId] || {})[sprintId];
  if (!data) return;

  var stories = data.stories.filter(function(s) {
    var matchA = !assignee || s.assignedTo === assignee;
    var matchT = !tag || (s.tags && s.tags.indexOf(tag) !== -1);
    return matchA && matchT;
  });

  var total = stories.length;
  var completed = stories.filter(function(s){ return DONE_STATES[s.state]; }).length;
  var pts = stories.reduce(function(a,s){ return a + (s.points || 0); }, 0);
  var donePts = stories.filter(function(s){ return DONE_STATES[s.state]; })
                       .reduce(function(a,s){ return a + (s.points || 0); }, 0);

  var checks = total * 4;
  var passed = stories.reduce(function(a,s){
    return a + (s.hasAc?1:0) + (s.hasPr?1:0) + (s.hasCommit?1:0) + (s.hasPoints?1:0);
  }, 0);
  var rate = checks > 0 ? Math.round(passed / checks * 100) : 100;

  setText('c-total-'   + teamId + '-' + sprintId, total);
  setText('c-done-'    + teamId + '-' + sprintId, completed);
  setText('c-pts-'     + teamId + '-' + sprintId, pts.toFixed(1).replace(/\.0$/,''));
  setText('c-donepts-' + teamId + '-' + sprintId, donePts.toFixed(1).replace(/\.0$/,''));
  setText('c-rate-'    + teamId + '-' + sprintId, rate + '%');

  var devS = stories.filter(function(s){return s.devDays!=null;}).map(function(s){return s.devDays;});
  var qaS  = stories.filter(function(s){return s.qaDays!=null;}).map(function(s){return s.qaDays;});
  var avgDev = devS.length ? (devS.reduce(function(a,v){return a+v;},0)/devS.length).toFixed(1) : '—';
  var avgQa  = qaS.length  ? (qaS.reduce(function(a,v){return a+v;},0)/qaS.length).toFixed(1)  : '—';
  setText('c-devdays-' + teamId + '-' + sprintId, avgDev);
  setText('c-qadays-'  + teamId + '-' + sprintId, avgQa);

  // Recompute health score for filtered view
  var compRate = total > 0 ? completed / total : 1;
  var totalRoadblocks = stories.reduce(function(a,s){ return a + (s.roadblockCount || 0); }, 0);
  var rbPenalty = Math.min(totalRoadblocks * 10, 20);
  var hs = Math.round(compRate * 40 + rate / 100 * 40 + (20 - rbPenalty));
  hs = Math.max(0, Math.min(100, hs));
  var hl = hs >= 75 ? 'green' : (hs >= 45 ? 'amber' : 'red');
  var hCard = document.querySelector('#cards-' + teamId + '-' + sprintId + ' .card.health-green, #cards-' + teamId + '-' + sprintId + ' .card.health-amber, #cards-' + teamId + '-' + sprintId + ' .card.health-red');
  if (hCard) {
    hCard.className = 'card health-' + hl;
    var hVal = hCard.querySelector('.value');
    if (hVal) hVal.textContent = hs;
  }
  var hBar = document.querySelector('#sprint-' + teamId + '-' + sprintId + ' .sprint-health-bar');
  if (hBar) {
    hBar.className = 'sprint-health-bar ' + hl;
    var hBarStrong = hBar.querySelector('strong');
    if (hBarStrong) hBarStrong.textContent = hs + ' / 100';
    var hDot = hBar.querySelector('.health-dot');
    if (hDot) hDot.className = 'health-dot health-dot-' + hl;
  }
}

function setText(id, val) {
  var el = document.getElementById(id);
  if (el) el.textContent = val;
}

function showPersonSummary(teamId, assignee) {
  var ps = document.getElementById('ps-' + teamId);
  if (!ps) return;

  document.getElementById('ps-title-' + teamId).textContent = assignee + ' — Sprint-wise Summary';

  var teamData = teamStoryData[teamId] || {};
  var sprintIds = Object.keys(teamData).sort(function(a, b) {
    var na = teamData[a].name || '';
    var nb = teamData[b].name || '';
    return na < nb ? -1 : na > nb ? 1 : 0;
  });

  var rows = '';
  var chartLabels = [], chartTotal = [], chartDone = [];

  sprintIds.forEach(function(sprintId) {
    var data = teamData[sprintId];
    var stories = data.stories.filter(function(s){ return s.assignedTo === assignee; });
    if (!stories.length && !data.isCurrent) return;

    var total = stories.length;
    var completed = stories.filter(function(s){ return DONE_STATES[s.state]; }).length;
    var donePts = stories.filter(function(s){ return DONE_STATES[s.state]; })
                         .reduce(function(a,s){ return a + (s.points||0); }, 0);
    var pct = total > 0 ? Math.round(completed / total * 100) : 0;

    var shortName = data.name.length > 18 ? data.name.slice(-18) : data.name;
    chartLabels.push(shortName);
    chartTotal.push(total);
    chartDone.push(completed);

    rows += '<tr>'
      + '<td>' + escHtml(shortName) + '</td>'
      + '<td class="num">' + total + '</td>'
      + '<td class="num">' + completed + '</td>'
      + '<td class="num">' + (donePts || '—') + '</td>'
      + '<td class="pct-cell"><div class="pct-bar-wrap">'
      + '<div class="pct-bar-bg"><div class="pct-bar-fill" style="width:' + pct + '%"></div></div>'
      + '<span style="min-width:34px;font-size:12px;font-weight:700;color:#1a237e">' + pct + '%</span>'
      + '</div></td>'
      + '</tr>';
  });

  document.getElementById('ps-tbody-' + teamId).innerHTML = rows || '<tr><td colspan="5" style="text-align:center;color:#888;padding:12px">No stories found for this person.</td></tr>';
  ps.style.display = 'block';

  // Draw person mini-chart
  setTimeout(function() {
    drawBarChart('ps-chart-' + teamId, chartLabels, chartDone, chartTotal, true);
  }, 50);

  // Build all-completed items table (non-backlog sprints only, most-recent first)
  var bugIcon = '<svg width="12" height="12" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:3px;flex-shrink:0"><circle cx="7" cy="7" r="7" fill="#cc3311"/><circle cx="7" cy="7" r="2.8" fill="none" stroke="#fff" stroke-width="1.4"/><line x1="7" y1="1.5" x2="7" y2="12.5" stroke="#fff" stroke-width="1.2"/><line x1="1.5" y1="7" x2="12.5" y2="7" stroke="#fff" stroke-width="1.2"/></svg>';
  var storyIcon = '<svg width="12" height="12" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:3px;flex-shrink:0"><rect width="14" height="14" rx="2" fill="#773388"/><path d="M3 2h8v10L7 9.2 3 12z" fill="#fff" opacity=".9"/></svg>';

  var allCompleted = [];
  sprintIds.forEach(function(sprintId) {
    var data = teamData[sprintId];
    if (!data.isCurrent) return; // skip backlog
    (data.stories || []).forEach(function(s) {
      if (s.assignedTo === assignee && DONE_STATES[s.state]) {
        allCompleted.push(Object.assign({}, s, {sprintName: data.name}));
      }
    });
  });
  // Most-recent sprint first (sort descending by sprint name)
  allCompleted.sort(function(a, b) {
    return a.sprintName > b.sprintName ? -1 : a.sprintName < b.sprintName ? 1 : 0;
  });

  var completedTitle = document.getElementById('ps-completed-title-' + teamId);
  if (completedTitle) completedTitle.textContent = 'All Completed Items — ' + assignee + ' (' + allCompleted.length + ')';

  var completedWrap = document.getElementById('ps-completed-' + teamId);
  if (!completedWrap) return;
  if (!allCompleted.length) {
    completedWrap.innerHTML = '<p style="color:#888;text-align:center;padding:16px;font-size:13px">No completed items found.</p>';
    return;
  }
  var html = '<table class="ps-completed-table"><thead><tr>'
    + '<th>Sprint</th><th>Title</th><th>State</th>'
    + '<th class="num">Points</th><th class="num">Dev Days</th><th class="num">QA Days</th>'
    + '</tr></thead><tbody>';
  allCompleted.forEach(function(s) {
    var icon = s.witType === 'Bug' ? bugIcon : storyIcon;
    var titleCell = s.adoUrl
      ? '<a href="' + escHtml(s.adoUrl) + '" target="_blank" style="color:#0d47a1;text-decoration:none">' + icon + escHtml(s.title) + '</a>'
      : icon + escHtml(s.title);
    html += '<tr>'
      + '<td style="white-space:nowrap;font-size:11px;color:#555">' + escHtml(s.sprintName) + '</td>'
      + '<td style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + escHtml(s.title) + '">' + titleCell + '</td>'
      + '<td><span class="state-badge state-' + escHtml(s.state) + '">' + escHtml(s.state) + '</span></td>'
      + '<td class="num">' + (s.points || '—') + '</td>'
      + '<td class="num">' + (s.devDays != null ? s.devDays : '—') + '</td>'
      + '<td class="num">' + (s.qaDays != null ? s.qaDays : '—') + '</td>'
      + '</tr>';
  });
  html += '</tbody></table>';
  completedWrap.innerHTML = html;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Sprint / team switching ────────────────────────────────────────────────
function switchTeam(teamId) {
  document.querySelectorAll('.team-panel').forEach(function(p){ p.classList.remove('active'); });
  var panel = document.getElementById('team-' + teamId);
  if (panel) panel.classList.add('active');
  // Sync static dropdown if present (batch mode)
  var sel = document.getElementById('team-select');
  if (sel) sel.value = teamId;
}

function switchSprint(teamId, sprintId) {
  var panel = document.getElementById('team-' + teamId);
  if (!panel) return;
  panel.querySelectorAll('.sprint-summary-panel').forEach(function(p){ p.classList.remove('active'); });
  var target = document.getElementById('sprint-' + teamId + '-' + sprintId);
  if (target) target.classList.add('active');

  // Re-apply active filters for the newly shown sprint
  filterSprintTable(teamId, sprintId);
}

// ── Tag filter ────────────────────────────────────────────────────────────
function buildTagDropdowns() {
  Object.keys(teamStoryData).forEach(function(teamId) {
    var seen = {};
    Object.keys(teamStoryData[teamId]).forEach(function(sprintId) {
      (teamStoryData[teamId][sprintId].stories || []).forEach(function(s) {
        (s.tags || []).forEach(function(tag) { if (tag) seen[tag] = true; });
      });
    });
    var tags = Object.keys(seen).sort();
    var sel = document.getElementById('tag-select-' + teamId);
    if (!sel) return;
    tags.forEach(function(tag) {
      var opt = document.createElement('option');
      opt.value = tag;
      opt.textContent = tag;
      sel.appendChild(opt);
    });
  });
}

function applyTagFilter(teamId, tag) {
  activeTag[teamId] = tag;
  var teamData = teamStoryData[teamId] || {};
  Object.keys(teamData).forEach(function(sprintId) {
    filterSprintTable(teamId, sprintId);
  });
}

// ── Canvas bar chart ───────────────────────────────────────────────────────
function drawBarChart(canvasId, labels, completedData, totalData, compact) {
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W = compact ? (canvas.offsetWidth || 500) : 1000;
  var H = compact ? 180 : 400;
  canvas.width = W;
  canvas.height = H;
  ctx.clearRect(0,0,W,H);

  var n = labels.length;
  if (!n) return;
  var padL=48, padR=20, padT=24, padB=compact?48:72;
  var maxVal = Math.max.apply(null, totalData.concat([1]));
  var chartW = W - padL - padR;
  var chartH = H - padT - padB;
  var groupW = chartW / n;
  var barW = Math.min(groupW * 0.38, 40);

  // Horizontal grid lines
  ctx.strokeStyle='#e8eaf6'; ctx.lineWidth=1;
  for (var i=0; i<=5; i++) {
    var y = padT + chartH - (chartH * i / 5);
    ctx.beginPath(); ctx.moveTo(padL,y); ctx.lineTo(W-padR,y); ctx.stroke();
    ctx.fillStyle='#999'; ctx.font='10px sans-serif'; ctx.textAlign='right';
    ctx.fillText(Math.round(maxVal*i/5), padL-6, y+4);
  }

  labels.forEach(function(label, i) {
    var x = padL + i * groupW + groupW/2;

    // Total bar (light)
    var totalH = totalData[i] > 0 ? Math.max((totalData[i] / maxVal) * chartH, 2) : 0;
    ctx.fillStyle='#c5cae9';
    ctx.fillRect(x - barW - 1, padT + chartH - totalH, barW, totalH);
    if (totalData[i] > 0) {
      ctx.fillStyle='#5c6bc0'; ctx.font='bold 10px sans-serif'; ctx.textAlign='center';
      ctx.fillText(totalData[i], x - barW/2 - 1, padT + chartH - totalH - 4);
    }

    // Completed bar (dark)
    var compH = completedData[i] > 0 ? Math.max((completedData[i] / maxVal) * chartH, 2) : 0;
    ctx.fillStyle='#1a237e';
    ctx.fillRect(x + 1, padT + chartH - compH, barW, compH);
    if (completedData[i] > 0) {
      ctx.fillStyle='#fff'; ctx.font='bold 10px sans-serif'; ctx.textAlign='center';
      ctx.fillText(completedData[i], x + barW/2 + 1, padT + chartH - compH + 12);
    }

    // Angled x-axis label (short sprint name)
    if (!compact) {
      var m = label.match(/S\d+/);
      var lbl = m ? m[0] : (label.length > 8 ? label.slice(-8) : label);
      ctx.save();
      ctx.fillStyle='#444'; ctx.font='11px sans-serif'; ctx.textAlign='right';
      ctx.translate(x + 4, padT + chartH + 10);
      ctx.rotate(-Math.PI / 4);
      ctx.fillText(lbl, 0, 0);
      ctx.restore();
    } else {
      var lbl2 = label.length > 10 ? label.slice(-10) : label;
      ctx.fillStyle='#555'; ctx.font='10px sans-serif'; ctx.textAlign='center';
      ctx.fillText(lbl2, x, H - padB + 14);
    }
  });

  // Legend (top-right corner inside chart area)
  var lx = W - padR - 160;
  var ly = padT + 2;
  ctx.fillStyle='#c5cae9'; ctx.fillRect(lx, ly, 12, 10);
  ctx.fillStyle='#444'; ctx.font='11px sans-serif'; ctx.textAlign='left';
  ctx.fillText('Total', lx+16, ly+9);
  ctx.fillStyle='#1a237e'; ctx.fillRect(lx+62, ly, 12, 10);
  ctx.fillText('Completed', lx+78, ly+9);
}

// ── Velocity trend line chart ─────────────────────────────────────────────
function drawVelocityChart(canvasId, labels, pointsDone, pointsTotal) {
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W = canvas.offsetWidth || 1000;
  var H = 340;
  canvas.width = W;
  canvas.height = H;
  ctx.clearRect(0, 0, W, H);

  var n = labels.length;
  if (!n) return;

  var padL = 52, padR = 24, padT = 32, padB = 80;
  var chartW = W - padL - padR;
  var chartH = H - padT - padB;

  var allVals = pointsDone.concat(pointsTotal).filter(function(v){ return v > 0; });
  var maxVal = allVals.length ? Math.max.apply(null, allVals) : 1;
  // Round up to a nice grid ceiling
  var step = Math.pow(10, Math.floor(Math.log(maxVal) / Math.log(10)));
  var gridMax = Math.ceil(maxVal / step) * step;
  var gridLines = 5;

  // Grid
  ctx.strokeStyle = '#e8eaf6'; ctx.lineWidth = 1;
  for (var i = 0; i <= gridLines; i++) {
    var val = gridMax * i / gridLines;
    var y = padT + chartH - (val / gridMax) * chartH;
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
    ctx.fillStyle = '#999'; ctx.font = '10px sans-serif'; ctx.textAlign = 'right';
    ctx.fillText(Math.round(val), padL - 6, y + 4);
  }

  // Y-axis label
  ctx.save();
  ctx.fillStyle = '#666'; ctx.font = '11px sans-serif'; ctx.textAlign = 'center';
  ctx.translate(12, padT + chartH / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('Story Points', 0, 0);
  ctx.restore();

  function xPos(i) { return padL + (n === 1 ? chartW / 2 : i * chartW / (n - 1)); }
  function yPos(v) { return padT + chartH - (v / gridMax) * chartH; }

  // 3-sprint rolling average of points done
  var rolling = pointsDone.map(function(_, i) {
    var slice = pointsDone.slice(Math.max(0, i - 2), i + 1);
    return slice.reduce(function(a, v) { return a + v; }, 0) / slice.length;
  });

  // Draw filled area under pointsDone line
  ctx.beginPath();
  ctx.moveTo(xPos(0), padT + chartH);
  for (var i2 = 0; i2 < n; i2++) ctx.lineTo(xPos(i2), yPos(pointsDone[i2]));
  ctx.lineTo(xPos(n - 1), padT + chartH);
  ctx.closePath();
  ctx.fillStyle = 'rgba(26,35,126,0.07)';
  ctx.fill();

  // Draw pointsTotal line (dashed, light)
  ctx.beginPath();
  ctx.setLineDash([5, 4]);
  ctx.strokeStyle = '#9fa8da'; ctx.lineWidth = 1.5;
  for (var i3 = 0; i3 < n; i3++) {
    if (i3 === 0) ctx.moveTo(xPos(i3), yPos(pointsTotal[i3]));
    else ctx.lineTo(xPos(i3), yPos(pointsTotal[i3]));
  }
  ctx.stroke();
  ctx.setLineDash([]);

  // Draw pointsDone line (solid, dark blue)
  ctx.beginPath();
  ctx.strokeStyle = '#1a237e'; ctx.lineWidth = 2.5;
  for (var i4 = 0; i4 < n; i4++) {
    if (i4 === 0) ctx.moveTo(xPos(i4), yPos(pointsDone[i4]));
    else ctx.lineTo(xPos(i4), yPos(pointsDone[i4]));
  }
  ctx.stroke();

  // Draw rolling average line (orange dashed)
  ctx.beginPath();
  ctx.setLineDash([6, 3]);
  ctx.strokeStyle = '#e65100'; ctx.lineWidth = 2;
  for (var i5 = 0; i5 < n; i5++) {
    if (i5 === 0) ctx.moveTo(xPos(i5), yPos(rolling[i5]));
    else ctx.lineTo(xPos(i5), yPos(rolling[i5]));
  }
  ctx.stroke();
  ctx.setLineDash([]);

  // Dots + value labels on pointsDone line
  for (var i6 = 0; i6 < n; i6++) {
    var cx2 = xPos(i6), cy2 = yPos(pointsDone[i6]);
    ctx.beginPath();
    ctx.arc(cx2, cy2, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#1a237e'; ctx.fill();
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.stroke();
    if (pointsDone[i6] > 0) {
      ctx.fillStyle = '#1a237e'; ctx.font = 'bold 10px sans-serif'; ctx.textAlign = 'center';
      ctx.fillText(pointsDone[i6], cx2, cy2 - 9);
    }
  }

  // X-axis labels (angled)
  for (var i7 = 0; i7 < n; i7++) {
    var m = labels[i7].match(/S\d+/);
    var lbl = m ? m[0] : (labels[i7].length > 8 ? labels[i7].slice(-8) : labels[i7]);
    ctx.save();
    ctx.fillStyle = '#444'; ctx.font = '11px sans-serif'; ctx.textAlign = 'right';
    ctx.translate(xPos(i7) + 4, padT + chartH + 10);
    ctx.rotate(-Math.PI / 4);
    ctx.fillText(lbl, 0, 0);
    ctx.restore();
  }

  // Legend
  var lx = W - padR - 290, ly = padT + 2;
  ctx.fillStyle = '#1a237e'; ctx.fillRect(lx, ly, 18, 3);
  ctx.beginPath(); ctx.arc(lx + 9, ly + 1.5, 4, 0, Math.PI * 2); ctx.fillStyle = '#1a237e'; ctx.fill();
  ctx.fillStyle = '#444'; ctx.font = '11px sans-serif'; ctx.textAlign = 'left';
  ctx.fillText('Points Done', lx + 26, ly + 5);

  lx += 110;
  ctx.setLineDash([5, 4]);
  ctx.strokeStyle = '#9fa8da'; ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(lx, ly + 2); ctx.lineTo(lx + 18, ly + 2); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#444'; ctx.textAlign = 'left';
  ctx.fillText('Points Total', lx + 24, ly + 5);

  lx += 108;
  ctx.setLineDash([6, 3]);
  ctx.strokeStyle = '#e65100'; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(lx, ly + 2); ctx.lineTo(lx + 18, ly + 2); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#444'; ctx.textAlign = 'left';
  ctx.fillText('3-Sprint Avg', lx + 24, ly + 5);
}

// ── Feature View ──────────────────────────────────────────────────────────
var featureData = {{ feature_data | tojson }};

function toggleView(teamId, view) {
  ['sprint', 'feature', 'pr'].forEach(function(v) {
    var panel = document.getElementById(v + '-view-' + teamId);
    var btn   = document.getElementById('vbtn-' + v + '-' + teamId);
    if (panel) panel.classList.toggle('active', v === view);
    if (btn)   btn.classList.toggle('active', v === view);
  });
  if (view === 'feature') {
    buildFeatureView(teamId);
  } else if (view === 'pr') {
    var sel = document.getElementById('pr-sprint-sel-' + teamId);
    if (sel && sel.value) buildPRView(teamId, sel.value);
  }
}

function buildPRView(teamId, sprintId) {
  var wrap = document.getElementById('pr-table-wrap-' + teamId);
  if (!wrap) return;

  var sprintData = (teamStoryData[teamId] || {})[sprintId];
  var prByIndividual = sprintData ? (sprintData.prByIndividual || {}) : {};
  var sprintName = sprintData ? sprintData.name : '';

  // Build the full ADO assignee set for this team across all sprints
  var teamAssignees = {};
  Object.keys(teamStoryData[teamId] || {}).forEach(function(sid) {
    ((teamStoryData[teamId][sid] || {}).stories || []).forEach(function(s) {
      if (s.assignedTo && s.assignedTo !== 'Unassigned') teamAssignees[s.assignedTo] = true;
    });
  });
  var hasTeamMap = Object.keys(teamAssignees).length > 0;

  var rows = Object.keys(prByIndividual)
    .filter(function(author) {
      if (!hasTeamMap) return true;
      var adoName = prByIndividual[author].assigned_to || '';
      // Only show if mapped to this team's ADO members; hide if unmapped or another team
      return adoName !== '' && teamAssignees[adoName] === true;
    })
    .map(function(author) {
      return { author: author, data: prByIndividual[author] };
    });
  rows.sort(function(a, b) { return b.data.prs_raised - a.data.prs_raised; });

  if (!rows.length) {
    wrap.innerHTML = '<div class="pr-no-data">No PR data found for this sprint.<br><small style="color:#aaa">PRs are tracked from GitHub links on ADO work items.</small></div>';
    return;
  }

  var html = '<table class="pr-table"><thead><tr>'
    + '<th>Individual (GitHub)</th>'
    + '<th style="text-align:right">PRs Raised</th>'
    + '<th style="text-align:right">Merged to Master</th>'
    + '<th style="text-align:right">Not Merged</th>'
    + '<th style="text-align:right">% Deployed</th>'
    + '<th style="text-align:right" title="PRs labelled AI Generated / AI Assisted / AI Powered">AI-Labeled PRs</th>'
    + '</tr></thead><tbody>';

  rows.forEach(function(r) {
    var d = r.data;
    var pct = d.pct_deployed;
    var pctClass = pct >= 80 ? 'pr-pct-green' : (pct >= 50 ? 'pr-pct-amber' : 'pr-pct-red');
    var aiCount = d.ai_labeled || 0;
    var aiPrs = d.ai_labeled_prs || [];
    var aiCell = aiCount > 0
      ? '<button class="ai-count-btn" onclick=\'openAiPrModal(' + JSON.stringify(r.author) + ',' + JSON.stringify(aiPrs) + ')\'>&#129302; ' + aiCount + '</button>'
      : '<span style="color:#bbb">0</span>';
    html += '<tr>'
      + '<td>' + escHtml(r.author) + '</td>'
      + '<td class="num">' + d.prs_raised + '</td>'
      + '<td class="num">' + d.merged_to_master + '</td>'
      + '<td class="num">' + d.not_merged + '</td>'
      + '<td class="num ' + pctClass + '">' + pct + '%</td>'
      + '<td class="num">' + aiCell + '</td>'
      + '</tr>';
  });

  html += '</tbody></table>';
  wrap.innerHTML = html;
}

var _featureViewBuilt = {};

function buildFeatureView(teamId) {
  if (_featureViewBuilt[teamId]) return;
  _featureViewBuilt[teamId] = true;

  var features = featureData[teamId] || [];
  var container = document.getElementById('fcards-' + teamId);
  if (!container) return;

  features.forEach(function(fe, idx) {
    var card = document.createElement('div');
    card.className = 'feature-card';
    card.setAttribute('data-idx', idx);
    var rbBadge = fe.roadblocks.length
      ? '<div class="fc-roadblock-badge">&#9888; ' + fe.roadblocks.length + ' roadblock' + (fe.roadblocks.length > 1 ? 's' : '') + '</div>'
      : '';
    card.innerHTML =
      '<div class="fc-name" title="' + escHtml(fe.name) + '">' + escHtml(fe.name) + '</div>'
      + '<div class="fc-counts">' + fe.completedItems + ' / ' + fe.totalItems + ' items &nbsp;&bull;&nbsp; '
      + (fe.donePoints || 0) + ' / ' + (fe.totalPoints || 0) + ' pts</div>'
      + '<div class="fc-bar-bg"><div class="fc-bar-fill" style="width:' + fe.completionPct + '%"></div></div>'
      + '<div class="fc-pct">' + fe.completionPct + '% complete</div>'
      + rbBadge;
    card.onclick = function() { openFeatureDetail(teamId, idx); };
    container.appendChild(card);
  });

}

function openFeatureDetail(teamId, idx) {
  var features = featureData[teamId] || [];
  var fe = features[idx];
  if (!fe) return;

  // Highlight active card
  var container = document.getElementById('fcards-' + teamId);
  if (container) {
    container.querySelectorAll('.feature-card').forEach(function(c) {
      c.classList.toggle('active', parseInt(c.getAttribute('data-idx')) === idx);
    });
  }

  document.getElementById('fd-title-' + teamId).textContent = fe.name + ' — Feature Detail';

  // Roadblocks
  var rbEl = document.getElementById('fd-roadblocks-' + teamId);
  if (rbEl) {
    if (fe.roadblocks.length) {
      var items = fe.roadblocks.map(function(r) {
        var wiLink = r.ado_url
          ? '<a href="' + escHtml(r.ado_url) + '" target="_blank" style="color:#0d47a1;font-weight:700;text-decoration:none" title="Open work item">#' + r.id + ' ' + escHtml(r.title) + '</a>'
          : '<strong>#' + r.id + ' ' + escHtml(r.title) + '</strong>';
        return '<li style="margin-bottom:7px">'
          + '<div style="font-size:11px;margin-bottom:2px">' + wiLink + '</div>'
          + '<div style="color:#7a5200">' + escHtml(r.text) + '</div>'
          + '</li>';
      }).join('');
      rbEl.innerHTML = '<h4>&#9888; Roadblocks / Blockers</h4><ul style="list-style:none;padding:0">' + items + '</ul>';
      rbEl.style.display = '';
    } else {
      rbEl.innerHTML = '<h4 style="color:#2e7d32">&#10003; No roadblocks detected</h4>'
        + '<p style="font-size:12px;color:#666;margin-top:6px">No blocking signals found in this feature\'s work items.</p>';
      rbEl.style.background = '#f1f8e9';
      rbEl.style.borderColor = '#a5d6a7';
      rbEl.style.display = '';
    }
  }

  // Sprint trend chart
  setTimeout(function() {
    var trend = fe.sprintTrend || [];
    var labels  = trend.map(function(b) { return b.sprint.length > 14 ? b.sprint.slice(-14) : b.sprint; });
    var totals  = trend.map(function(b) { return b.total; });
    var done    = trend.map(function(b) { return b.completed; });
    drawBarChart('fd-chart-' + teamId, labels, done, totals, true);
  }, 50);

  // Story table
  var tbody = document.getElementById('fd-tbody-' + teamId);
  if (tbody) {
    var bugIcon = '<svg width="12" height="12" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:3px"><circle cx="7" cy="7" r="7" fill="#cc3311"/><circle cx="7" cy="7" r="2.8" fill="none" stroke="#fff" stroke-width="1.4"/><line x1="7" y1="1.5" x2="7" y2="12.5" stroke="#fff" stroke-width="1.2"/><line x1="1.5" y1="7" x2="12.5" y2="7" stroke="#fff" stroke-width="1.2"/></svg>';
    var storyIcon = '<svg width="12" height="12" viewBox="0 0 14 14" style="vertical-align:middle;margin-right:3px"><rect width="14" height="14" rx="2" fill="#773388"/><path d="M3 2h8v10L7 9.2 3 12z" fill="#fff" opacity=".9"/></svg>';
    var html = '';
    (fe.stories || []).forEach(function(s) {
      var icon = s.witType === 'Bug' ? bugIcon : storyIcon;
      var titleCell = s.adoUrl
        ? '<a href="' + escHtml(s.adoUrl) + '" target="_blank" style="color:#0d47a1;text-decoration:none">' + icon + escHtml(s.title) + '</a>'
        : icon + escHtml(s.title);
      html += '<tr>'
        + '<td style="white-space:nowrap;font-size:11px;color:#555">' + escHtml(s.sprintName || '') + '</td>'
        + '<td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + escHtml(s.title) + '">' + titleCell + '</td>'
        + '<td><span class="state-badge state-' + escHtml(s.state) + '">' + escHtml(s.state) + '</span></td>'
        + '<td style="white-space:nowrap">' + escHtml(s.assignedTo || '') + '</td>'
        + '<td class="num">' + (s.points || '—') + '</td>'
        + '</tr>';
    });
    tbody.innerHTML = html || '<tr><td colspan="5" style="text-align:center;color:#888;padding:12px">No items.</td></tr>';
  }

  document.getElementById('fdetail-' + teamId).classList.add('active');
}

function closeFeatureDetail(teamId) {
  var el = document.getElementById('fdetail-' + teamId);
  if (el) el.classList.remove('active');
  var container = document.getElementById('fcards-' + teamId);
  if (container) container.querySelectorAll('.feature-card').forEach(function(c) { c.classList.remove('active'); });
}

