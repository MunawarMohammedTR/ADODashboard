// ── Serve-mode: team list + on-demand loading ──────────────────────────────
var _allTeams = [];
var _loadedTeams = {};
var _prefetchInFlight = {};
var _prefetchCache = {};   // teamId → html string

var _LS_PREFIX = 'ado_panel_';
var _LS_TS_PREFIX = 'ado_panel_ts_';
var _CACHE_TTL = 30 * 60 * 1000; // 30 min session cache

function _lsGet(teamId) {
  try {
    var ts = parseInt(localStorage.getItem(_LS_TS_PREFIX + teamId) || '0');
    if (Date.now() - ts > _CACHE_TTL) return null;
    return localStorage.getItem(_LS_PREFIX + teamId);
  } catch(e) { return null; }
}
function _lsSet(teamId, html) {
  try {
    localStorage.setItem(_LS_PREFIX + teamId, html);
    localStorage.setItem(_LS_TS_PREFIX + teamId, String(Date.now()));
  } catch(e) {}
}

fetch('/teams')
  .then(function(r){ return r.json(); })
  .then(function(teams){
    _allTeams = teams;
    _renderSidebarList(teams);
  })
  .catch(function(){ document.getElementById('sidebar-empty').textContent = 'Failed to load teams.'; });

function _renderSidebarList(teams) {
  var list = document.getElementById('sidebar-list');
  var empty = document.getElementById('sidebar-empty');
  if (!teams.length) { if (empty) empty.textContent = 'No teams found.'; return; }
  if (empty) empty.style.display = 'none';
  list.innerHTML = '';
  teams.forEach(function(t) {
    var el = document.createElement('div');
    el.className = 'sidebar-item';
    el.id = 'sitem-' + t.id;
    el.setAttribute('data-id', t.id);
    el.setAttribute('data-name', t.name);
    el.innerHTML = '<span class="sidebar-health-dot" id="sdot-'+t.id+'"></span>'
      + '<span class="sidebar-item-name">'+escHtml(t.name)+'</span>';
    el.addEventListener('mouseenter', function(){ prefetchTeam(t.id); });
    el.addEventListener('click', function(){ loadTeam(t.id); });
    list.appendChild(el);
  });
}

function onSidebarSearch(q) {
  var items = document.querySelectorAll('#sidebar-list .sidebar-item');
  var lq = q.toLowerCase();
  items.forEach(function(el) {
    var name = (el.getAttribute('data-name') || '').toLowerCase();
    el.style.display = (!q || name.indexOf(lq) !== -1) ? '' : 'none';
  });
}

function prefetchTeam(teamId) {
  if (_loadedTeams[teamId] || _prefetchInFlight[teamId] || _prefetchCache[teamId]) return;
  var cached = _lsGet(teamId);
  if (cached) { _prefetchCache[teamId] = cached; return; }
  _prefetchInFlight[teamId] = true;
  fetch('/team-panel/' + encodeURIComponent(teamId))
    .then(function(r){ if(!r.ok) throw new Error('HTTP '+r.status); return r.text(); })
    .then(function(html){ _prefetchCache[teamId] = html; _lsSet(teamId, html); })
    .catch(function(){})
    .finally(function(){ delete _prefetchInFlight[teamId]; });
}

function _showSkeleton() {
  var inner = document.getElementById('content-inner');
  inner.innerHTML = '<div class="skeleton-panel">'
    +'<div class="sk-cards">'
    +'<div class="skeleton sk-card"></div><div class="skeleton sk-card"></div>'
    +'<div class="skeleton sk-card"></div><div class="skeleton sk-card"></div>'
    +'<div class="skeleton sk-card"></div><div class="skeleton sk-card"></div>'
    +'</div>'
    +'<div class="skeleton sk-bar w80"></div>'
    +'<div class="skeleton sk-bar w60" style="margin-bottom:18px"></div>'
    +'<div class="skeleton sk-table"></div>'
    +'</div>';
}

function loadTeam(teamId) {
  // Mark sidebar active immediately
  document.querySelectorAll('.sidebar-item').forEach(function(el){ el.classList.remove('active'); });
  var sitem = document.getElementById('sitem-' + teamId); if (sitem) sitem.classList.add('active');

  if (_loadedTeams[teamId]) {
    // Already in DOM — just switch
    document.querySelectorAll('.team-panel').forEach(function(p){ p.classList.remove('active'); });
    var panel = document.getElementById('team-' + teamId);
    if (panel) { panel.classList.add('active'); _ensureEmptyStateHidden(); }
    return;
  }

  var fromCache = _prefetchCache[teamId] || _lsGet(teamId);
  if (fromCache) {
    _injectTeamPanel(teamId, fromCache);
    return;
  }

  // Show skeleton while fetching
  _showSkeleton();

  fetch('/team-panel/' + encodeURIComponent(teamId))
    .then(function(r){ if(!r.ok) throw new Error('HTTP '+r.status); return r.text(); })
    .then(function(html){
      _prefetchCache[teamId] = html;
      _lsSet(teamId, html);
      _injectTeamPanel(teamId, html);
    })
    .catch(function(err){
      document.getElementById('content-inner').innerHTML =
        '<div class="empty-state"><div class="empty-state-icon">&#9888;</div><h2>Load failed</h2><p>'+escHtml(err.message)+'</p></div>';
    });
}

function _injectTeamPanel(teamId, html) {
  // Remove skeleton / empty state and inject real panel
  var inner = document.getElementById('content-inner');
  // Preserve existing loaded panels, just remove skeleton
  var skEl = inner.querySelector('.skeleton-panel,.empty-state');
  if (skEl) skEl.remove();

  // Hide all existing panels
  inner.querySelectorAll('.team-panel').forEach(function(p){ p.classList.remove('active'); });

  // If not yet in DOM, append
  if (!document.getElementById('team-' + teamId)) {
    var tmp = document.createElement('div');
    tmp.innerHTML = html;
    Array.prototype.forEach.call(tmp.childNodes, function(node){ inner.appendChild(node); });
  }

  _loadedTeams[teamId] = true;
  document.querySelectorAll('.team-panel').forEach(function(p){ p.classList.remove('active'); });
  var panel = document.getElementById('team-' + teamId);
  if (panel) panel.classList.add('active');

  _initLoadedTeam(teamId);
  _ensureEmptyStateHidden();
}

function _ensureEmptyStateHidden() {
  var es = document.getElementById('empty-state'); if (es) es.remove();
}

function _initLoadedTeam(teamId) {
  var seenA={};
  Object.keys(teamStoryData[teamId]||{}).forEach(function(sid){
    (teamStoryData[teamId][sid].stories||[]).forEach(function(s){ if(s.assignedTo) seenA[s.assignedTo]=true; });
  });
  var selA = document.getElementById('af-'+teamId);
  if (selA) Object.keys(seenA).sort().forEach(function(n){ var o=document.createElement('option');o.value=n;o.textContent=n;selA.appendChild(o); });

  var seenT={};
  Object.keys(teamStoryData[teamId]||{}).forEach(function(sid){
    (teamStoryData[teamId][sid].stories||[]).forEach(function(s){ (s.tags||[]).forEach(function(t){ if(t) seenT[t]=true; }); });
  });
  var selT = document.getElementById('tag-select-'+teamId);
  if (selT) Object.keys(seenT).sort().forEach(function(tag){ var o=document.createElement('option');o.value=tag;o.textContent=tag;selT.appendChild(o); });

  var prSel = document.getElementById('pr-sprint-sel-'+teamId);
  if (prSel && prSel.options.length) prSel.selectedIndex = prSel.options.length-1;

  // Update sidebar health dot
  var dot = document.getElementById('sdot-'+teamId);
  if (dot) {
    var sprints = Object.values(teamStoryData[teamId]||{});
    var last = sprints.length ? sprints[sprints.length-1] : null;
    if (last) {
      var sts=last.stories||[], total=sts.length;
      var done=sts.filter(function(s){return DONE_STATES[s.state];}).length;
      var chk=total*4, passed=sts.reduce(function(a,s){return a+(s.hasAc?1:0)+(s.hasPr?1:0)+(s.hasCommit?1:0)+(s.hasPoints?1:0);},0);
      var rate=chk>0?Math.round(passed/chk*100):100, compR=total>0?done/total:1;
      var hs=Math.max(0,Math.min(100,Math.round(compR*40+rate/100*40+20)));
      dot.className='sidebar-health-dot '+(hs>=75?'green':(hs>=45?'amber':'red'));
    }
  }

  var d = chartData[teamId];
  if (d) {
    setTimeout(function(){
      drawBarChart('chart-'+teamId, d.labels, d.completed, d.total, false);
      drawVelocityChart('velocity-chart-'+teamId, d.labels, d.points_done, d.points_total);
    }, 50);
  }
}

// ── Live Refresh ───────────────────────────────────────────────────────────
function refreshDashboard() {
  var btn = document.getElementById('refresh-btn');
  btn.disabled = true; btn.textContent = 'Fetching...';
  // Invalidate localStorage cache
  try {
    Object.keys(localStorage).filter(function(k){ return k.startsWith(_LS_PREFIX)||k.startsWith(_LS_TS_PREFIX); })
      .forEach(function(k){ localStorage.removeItem(k); });
  } catch(e) {}
  _prefetchCache = {};
  fetch('/refresh', {method:'POST'})
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (d.started || d.reason==='already running') _pollRefreshStatus();
      else { btn.disabled=false; btn.textContent='Refresh'; }
    })
    .catch(function(){ btn.disabled=false; btn.textContent='Network error'; });
}

function _pollRefreshStatus() {
  var btn = document.getElementById('refresh-btn');
  var dots = 0;
  function tick() {
    dots = (dots%3)+1;
    btn.textContent = 'Fetching'+'.'.repeat(dots);
    fetch('/status').then(function(r){return r.json();}).then(function(d){
      if (d.error) { btn.disabled=false; btn.textContent='Error — retry'; }
      else if (!d.refreshing) { window.location.reload(); }
      else { setTimeout(tick, 3000); }
    }).catch(function(){ setTimeout(tick, 5000); });
  }
  tick();
}
{% endif %}
</script>

