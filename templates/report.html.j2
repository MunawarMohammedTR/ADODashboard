// ── Charts ─────────────────────────────────────────────────────────────────
function drawBarChart(canvasId, labels, completedData, totalData, compact) {
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W = compact ? (canvas.offsetWidth || 500) : 1000;
  var H = compact ? 180 : 400;
  canvas.width = W; canvas.height = H;
  ctx.clearRect(0,0,W,H);
  var n = labels.length; if (!n) return;
  var padL=48,padR=20,padT=24,padB=compact?48:72;
  var maxVal = Math.max.apply(null,totalData.concat([1]));
  var chartW=W-padL-padR, chartH=H-padT-padB;
  var groupW=chartW/n, barW=Math.min(groupW*0.38,40);
  ctx.strokeStyle='#e8eaf6'; ctx.lineWidth=1;
  for (var i=0;i<=5;i++) {
    var y=padT+chartH-(chartH*i/5);
    ctx.beginPath(); ctx.moveTo(padL,y); ctx.lineTo(W-padR,y); ctx.stroke();
    ctx.fillStyle='#999'; ctx.font='10px sans-serif'; ctx.textAlign='right';
    ctx.fillText(Math.round(maxVal*i/5),padL-6,y+4);
  }
  labels.forEach(function(label,i) {
    var x=padL+i*groupW+groupW/2;
    var totalH=totalData[i]>0?Math.max((totalData[i]/maxVal)*chartH,2):0;
    ctx.fillStyle='#c5cae9'; ctx.fillRect(x-barW-1,padT+chartH-totalH,barW,totalH);
    if(totalData[i]>0){ctx.fillStyle='#5c6bc0';ctx.font='bold 10px sans-serif';ctx.textAlign='center';ctx.fillText(totalData[i],x-barW/2-1,padT+chartH-totalH-4);}
    var compH=completedData[i]>0?Math.max((completedData[i]/maxVal)*chartH,2):0;
    ctx.fillStyle='#1a237e'; ctx.fillRect(x+1,padT+chartH-compH,barW,compH);
    if(completedData[i]>0){ctx.fillStyle='#fff';ctx.font='bold 10px sans-serif';ctx.textAlign='center';ctx.fillText(completedData[i],x+barW/2+1,padT+chartH-compH+12);}
    if(!compact){
      var m=label.match(/S\d+/); var lbl=m?m[0]:(label.length>8?label.slice(-8):label);
      ctx.save();ctx.fillStyle='#444';ctx.font='11px sans-serif';ctx.textAlign='right';
      ctx.translate(x+4,padT+chartH+10);ctx.rotate(-Math.PI/4);ctx.fillText(lbl,0,0);ctx.restore();
    } else {
      var lbl2=label.length>10?label.slice(-10):label;
      ctx.fillStyle='#555';ctx.font='10px sans-serif';ctx.textAlign='center';ctx.fillText(lbl2,x,H-padB+14);
    }
  });
  var lx=W-padR-160,ly=padT+2;
  ctx.fillStyle='#c5cae9';ctx.fillRect(lx,ly,12,10);
  ctx.fillStyle='#444';ctx.font='11px sans-serif';ctx.textAlign='left';ctx.fillText('Total',lx+16,ly+9);
  ctx.fillStyle='#1a237e';ctx.fillRect(lx+62,ly,12,10);ctx.fillText('Completed',lx+78,ly+9);
}

function drawVelocityChart(canvasId, labels, pointsDone, pointsTotal) {
  var canvas = document.getElementById(canvasId);
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W=canvas.offsetWidth||1000, H=340;
  canvas.width=W; canvas.height=H; ctx.clearRect(0,0,W,H);
  var n=labels.length; if(!n) return;
  var padL=52,padR=24,padT=32,padB=80,chartW=W-padL-padR,chartH=H-padT-padB;
  var allVals=pointsDone.concat(pointsTotal).filter(function(v){return v>0;});
  var maxVal=allVals.length?Math.max.apply(null,allVals):1;
  var step=Math.pow(10,Math.floor(Math.log(maxVal)/Math.log(10)));
  var gridMax=Math.ceil(maxVal/step)*step, gridLines=5;
  ctx.strokeStyle='#e8eaf6'; ctx.lineWidth=1;
  for(var i=0;i<=gridLines;i++){
    var val=gridMax*i/gridLines, y=padT+chartH-(val/gridMax)*chartH;
    ctx.beginPath();ctx.moveTo(padL,y);ctx.lineTo(W-padR,y);ctx.stroke();
    ctx.fillStyle='#999';ctx.font='10px sans-serif';ctx.textAlign='right';ctx.fillText(Math.round(val),padL-6,y+4);
  }
  ctx.save();ctx.fillStyle='#666';ctx.font='11px sans-serif';ctx.textAlign='center';
  ctx.translate(12,padT+chartH/2);ctx.rotate(-Math.PI/2);ctx.fillText('Story Points',0,0);ctx.restore();
  function xP(i){return padL+(n===1?chartW/2:i*chartW/(n-1));}
  function yP(v){return padT+chartH-(v/gridMax)*chartH;}
  var rolling=pointsDone.map(function(_,i){var s=pointsDone.slice(Math.max(0,i-2),i+1);return s.reduce(function(a,v){return a+v;},0)/s.length;});
  ctx.beginPath();ctx.moveTo(xP(0),padT+chartH);
  for(var i2=0;i2<n;i2++) ctx.lineTo(xP(i2),yP(pointsDone[i2]));
  ctx.lineTo(xP(n-1),padT+chartH);ctx.closePath();ctx.fillStyle='rgba(26,35,126,0.07)';ctx.fill();
  ctx.beginPath();ctx.setLineDash([5,4]);ctx.strokeStyle='#9fa8da';ctx.lineWidth=1.5;
  for(var i3=0;i3<n;i3++){if(i3===0)ctx.moveTo(xP(i3),yP(pointsTotal[i3]));else ctx.lineTo(xP(i3),yP(pointsTotal[i3]));}
  ctx.stroke();ctx.setLineDash([]);
  ctx.beginPath();ctx.strokeStyle='#1a237e';ctx.lineWidth=2.5;
  for(var i4=0;i4<n;i4++){if(i4===0)ctx.moveTo(xP(i4),yP(pointsDone[i4]));else ctx.lineTo(xP(i4),yP(pointsDone[i4]));}
  ctx.stroke();
  ctx.beginPath();ctx.setLineDash([6,3]);ctx.strokeStyle='#e65100';ctx.lineWidth=2;
  for(var i5=0;i5<n;i5++){if(i5===0)ctx.moveTo(xP(i5),yP(rolling[i5]));else ctx.lineTo(xP(i5),yP(rolling[i5]));}
  ctx.stroke();ctx.setLineDash([]);
  for(var i6=0;i6<n;i6++){
    var cx2=xP(i6),cy2=yP(pointsDone[i6]);
    ctx.beginPath();ctx.arc(cx2,cy2,4,0,Math.PI*2);ctx.fillStyle='#1a237e';ctx.fill();
    ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();
    if(pointsDone[i6]>0){ctx.fillStyle='#1a237e';ctx.font='bold 10px sans-serif';ctx.textAlign='center';ctx.fillText(pointsDone[i6],cx2,cy2-9);}
  }
  for(var i7=0;i7<n;i7++){
    var m=labels[i7].match(/S\d+/); var lbl=m?m[0]:(labels[i7].length>8?labels[i7].slice(-8):labels[i7]);
    ctx.save();ctx.fillStyle='#444';ctx.font='11px sans-serif';ctx.textAlign='right';
    ctx.translate(xP(i7)+4,padT+chartH+10);ctx.rotate(-Math.PI/4);ctx.fillText(lbl,0,0);ctx.restore();
  }
  var lx=W-padR-290,ly=padT+2;
  ctx.fillStyle='#1a237e';ctx.fillRect(lx,ly,18,3);
  ctx.beginPath();ctx.arc(lx+9,ly+1.5,4,0,Math.PI*2);ctx.fillStyle='#1a237e';ctx.fill();
  ctx.fillStyle='#444';ctx.font='11px sans-serif';ctx.textAlign='left';ctx.fillText('Points Done',lx+26,ly+5);
  lx+=110;ctx.setLineDash([5,4]);ctx.strokeStyle='#9fa8da';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.moveTo(lx,ly+2);ctx.lineTo(lx+18,ly+2);ctx.stroke();ctx.setLineDash([]);
  ctx.fillStyle='#444';ctx.textAlign='left';ctx.fillText('Points Total',lx+24,ly+5);
  lx+=108;ctx.setLineDash([6,3]);ctx.strokeStyle='#e65100';ctx.lineWidth=2;
  ctx.beginPath();ctx.moveTo(lx,ly+2);ctx.lineTo(lx+18,ly+2);ctx.stroke();ctx.setLineDash([]);
  ctx.fillStyle='#444';ctx.textAlign='left';ctx.fillText('3-Sprint Avg',lx+24,ly+5);
}

// ── Feature View ───────────────────────────────────────────────────────────
var _featureViewBuilt = {};

function toggleView(teamId, view) {
  ['sprint','feature','pr'].forEach(function(v) {
    var panel=document.getElementById(v+'-view-'+teamId);
    var btn=document.getElementById('vbtn-'+v+'-'+teamId);
    if(panel) panel.classList.toggle('active', v===view);
    if(btn)   btn.classList.toggle('active', v===view);
  });
  if (view==='feature') buildFeatureView(teamId);
  else if (view==='pr') { var sel=document.getElementById('pr-sprint-sel-'+teamId); if(sel&&sel.value) buildPRView(teamId,sel.value); }
}

function buildFeatureView(teamId) {
  if (_featureViewBuilt[teamId]) return;
  _featureViewBuilt[teamId] = true;
  var features = featureData[teamId] || [];
  var container = document.getElementById('fcards-' + teamId);
  if (!container) return;
  features.forEach(function(fe, idx) {
    var card = document.createElement('div');
    card.className = 'feature-card'; card.setAttribute('data-idx', idx);
    var rbBadge = fe.roadblocks.length ? '<div class="fc-roadblock-badge">&#9888; '+fe.roadblocks.length+' roadblock'+(fe.roadblocks.length>1?'s':'')+'</div>' : '';
    card.innerHTML = '<div class="fc-name" title="'+escHtml(fe.name)+'">'+escHtml(fe.name)+'</div>'
      +'<div class="fc-counts">'+fe.completedItems+' / '+fe.totalItems+' items &nbsp;&bull;&nbsp; '+(fe.donePoints||0)+' / '+(fe.totalPoints||0)+' pts</div>'
      +'<div class="fc-bar-bg"><div class="fc-bar-fill" style="width:'+fe.completionPct+'%"></div></div>'
      +'<div class="fc-pct">'+fe.completionPct+'% complete</div>'+rbBadge;
    card.onclick = function(){ openFeatureDetail(teamId, idx); };
    container.appendChild(card);
  });
}

function openFeatureDetail(teamId, idx) {
  var features = featureData[teamId] || [];
  var fe = features[idx]; if (!fe) return;
  var container = document.getElementById('fcards-' + teamId);
  if (container) container.querySelectorAll('.feature-card').forEach(function(c){ c.classList.toggle('active', parseInt(c.getAttribute('data-idx'))===idx); });
  document.getElementById('fd-title-'+teamId).textContent = fe.name + ' — Feature Detail';
  var rbEl = document.getElementById('fd-roadblocks-' + teamId);
  if (rbEl) {
    if (fe.roadblocks.length) {
      var items = fe.roadblocks.map(function(r){
        var wl = r.ado_url ? '<a href="'+escHtml(r.ado_url)+'" target="_blank" style="color:var(--text-link);font-weight:700;text-decoration:none">#'+r.id+' '+escHtml(r.title)+'</a>' : '<strong>#'+r.id+' '+escHtml(r.title)+'</strong>';
        return '<li style="margin-bottom:7px"><div style="font-size:11px;margin-bottom:2px">'+wl+'</div><div style="color:#7a5200">'+escHtml(r.text)+'</div></li>';
      }).join('');
      rbEl.innerHTML = '<h4>&#9888; Roadblocks</h4><ul style="list-style:none;padding:0">'+items+'</ul>';
      rbEl.style.background=''; rbEl.style.borderColor='';
    } else {
      rbEl.innerHTML = '<h4 style="color:var(--green)">&#10003; No roadblocks</h4><p style="font-size:12px;color:#666;margin-top:6px">No blocking signals found.</p>';
      rbEl.style.background='#f1f8e9'; rbEl.style.borderColor='#a5d6a7';
    }
  }
  setTimeout(function(){
    var trend=fe.sprintTrend||[];
